# Returns available space for uplaod, in bytes
freespace(){
    local quota=0 free=$(df --block-size=1 --output=avail "$data" | tail -n 1)
    local rest
    if [[ $freequota =~ ^([[:digit:]]+)[[:space:]]*([KMG]?)$ ]]; then
        quota="${BASH_REMATCH[1]}"
        case "${BASH_REMATCH[2]}" in
            K) ((quota *= 1024));;
            M) ((quota *= 1048576));;
            G) ((quota *= 1073741824));;
        esac
    elif [[ $freequota =~ ^([[:digit:]]+)[[:space:]]*%$ ]]; then
        local total=$(df --block-size=1 --output=size "$data" | tail -n 1)
        ((quota = "${BASH_REMATCH[1]}" * total / 100))
        ((rest = free - quota))
    fi
    ((rest = free - quota))
    ((rest < 0)) && echo 0 || echo "$rest"
}

