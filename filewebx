#!/bin/bash
# shellcheck disable=SC2155,SC1090,SC1091
VERSION=2.1.2
PROGNAME=filewebx
source='https://github.com/ColasNahaboo/filewebx'
copyright='(c)2026 Colas Nahaboo, MIT License'

# globals. Can be redefined in the sourced file ../filewebx.conf
configfile='../filewebx.conf'
validity=100
passlen=12                # length of the random "passwords", 10^14 combinations
freequota=30G             # Free space to leave on disk. K, M, G, % suffix
# MaxMind Geoip databases
geoipcity=/var/lib/GeoIP/GeoLite2-City.mmdb
geoipasn=/var/lib/GeoIP/GeoLite2-ASN.mmdb
declare -g root_url adminpass url urld data nl sp version gid isadmin isgadmin servertzone clienttzone dateformat localcss quota
lastip="$REMOTE_ADDR"

###################### Common

init(){
    root_url="$REQUEST_SCHEME://$HTTP_HOST"
    adminpass="${SCRIPT_NAME##*/}"   # adminpass or guestpass~guestid
    url="$root_url$SCRIPT_NAME"      # its URL
    urld="$root_url/_"               # URL of file downloader mini-script
    data=$(realpath '../data')       # metadata, logs, caches, guest ids...
    nl=$'\n'; tab=$'\t'; sp='&nbsp;' # some useful constants
    localcss=                        # extra CSS in config
    version="<p class=version><a href='$source'>${source##*/}</a> v$VERSION, $copyright</p>"

    servertzone=$(timedatectl|grep -oP 'Time zone: *\K[^, (]*')
    dateformat='%Y-%m-%d.%Hh%M,%S' # v2 dates format. ISO-ish but readable 
    meta-read-raw "$data/meta"
    if [[ -z "${metas[tzone,$REMOTE_ADDR]}" ]]; then
        clienttzone=$(get-client-tzone "$REMOTE_ADDR")
        [[ -z "$clienttzone" ]] && clienttzone="$servertzone"
        metas[tzone,$REMOTE_ADDR]="$clienttzone"
        meta-write-raw "$data/meta" # cache it
    else
        clienttzone="${metas[tzone,$REMOTE_ADDR]}"
    fi
    
    # are we the admin, or a guest account?
    if [[ $SCRIPT_NAME =~ /([[:alnum:]]+)([~][-_.[:alnum:]]+)$ ]]; then
        gid="/${BASH_REMATCH[2]}"       # guest id, in the form "/~guestid"
        isadmin=false
        data="$data$gid"
        mkdir -p "$data"
        urld="$urld$gid"
        meta-read-raw "$data/meta"
        [[ -n "${metas[admin]}" ]] && isgadmin=true || isgadmin=false
        adminpass=$(readlink "${SCRIPT_NAME##*/}")
    else
        gid=                            # admin
        isadmin=true
    fi
}

err() { echo "***ERROR: $*" >&2; exit 1; }

# args: subtitle comma-separated-tabs (active one postfixed by !)
header(){
    local title="${PROGNAME}${1:+: }${1}" tabs=",$2," guestlabel titlelabel
    if ! $isadmin; then
        guestlabel=" <span class=guest>[${gid#*~}]</span>"
        titlelabel=" [${gid#*~}]"
    fi
    echo "Content-Type: text/html$nl$nl<html><head>$localcss
<link rel=icon type='image/png' sizes='32x32' href='data:image/png;base64,$logo'>
<style>$style</style><title>$title$titlelabel</title>
<script>$javascript</script>
</head><body><header class='main-header'>
<div class='brand'><a href='$url'><img class=logo src='data:image/png;base64,$logo'> $title$guestlabel</a></div><nav class='nav-tabs'>"
    [[ $tabs =~ ,upload(!)?, ]] &&
        echo "<a href='$url' class='tab${BASH_REMATCH[1]:+ active}'>Upload</a>"
    [[ $tabs =~ ,logs(!)?, ]] &&
        echo "<a href='$url?mode=logs' class='tab${BASH_REMATCH[1]:+ active}'>Logs</a>"
    if [[ $tabs =~ ,admin(!)?, ]]; then
        if $isadmin; then
            echo "<a href='$url?mode=admin' class='tab${BASH_REMATCH[1]:+ active}'>Admin</a>"
        elif "$isgadmin"; then
            echo "<a href='$adminpass?mode=admin' class='tab${BASH_REMATCH[1]:+ active}'>Main Admin Account</a>"
        fi
    fi
    # shellcheck disable=SC2154        # FORM_xxx are defined by cgibashopts
    [[ $tabs =~ ,guest(!)?, ]] &&
        echo "<a href='$url' class='tab${BASH_REMATCH[1]:+ active}'>Account ${FORM_gid}</a>"
    echo "</nav></header>"
}
is-active(){
    [[ "$1" == "$2" ]] && echo " active"
}
footer(){
    echo "<hr><div class=minicontainer>$version</div></body></html>"
}
info(){
    # shellcheck disable=SC2154 # FORM_xxx are defined by cgibashopts
    local mess="${1:-$FORM_info}" class=info
    [[ -n "$mess" ]] || return
    [[ $mess =~ ^([[:alnum:]]+): ]] && class="$class ${BASH_REMATCH[1]}"
    [[ "$class" == info ]] && class="$class ok"
    echo "<div class='$class'>${mess^}</div>"
}
redirect(){
    echo "Location:$1$nl"
    exit 0
}

################################# Main upload mode

gui-upload(){
    local tabs="$1" pass ulfile filename size file metas another
    header '' "$tabs"
    info
    # Section: last uploaded file results
    if [ -n "${FORM_file:-}" ]; then
        ulfile="$CGIBASHOPTS_DIR/file"
        another=" another"
        echo "<div class=container>"
	if [ -s "$ulfile" ]; then
	    filename="${FORM_file##*/}"
            size=$(stat -c %s "$ulfile")
            if check-complete "$ulfile" "$size"; then # file is complete
                pass=$(random_string "$passlen")
                file="$data/$pass,$filename"
                meta="$data/$pass.meta"
	        mv "$ulfile" "$file"
                meta-reset
                metas[expire]="$(date -d "+$validity days" --iso)"
                metas[upload]="$(date +%Y-%m-%dT%H:%M:%S)"
                metas[name]="$filename"
	        metas[uname]="$(urlencode "$filename")"
	        metas[hname]="$(htmlencode "$filename")"
                metas[url]="${urld}/$pass/${metas[uname]}"
                metas[surl]="${urld}/$pass/"
                metas[hsize]="$(human_size "$size")"
                meta-write-raw "$meta"
                info "success!<p>
	        File uploaded (${metas[hsize]}), can be downloaded as the shareable link URL:
<div class='copy-wrapper'>
  <input type='text' 
         class='copy-input' 
         value='${metas[url]}'
         style='width: $((${#metas[url]}+2))ch;'
         readonly 
         onclick='copyEffect(this)' 
         title='Click to copy'>
  <span class='copy-icon-trigger'  title='Click to copy' onclick='copyEffect(this.previousElementSibling)'>$copyicon</span><span class='copy-popup'>Copied!</span>
</div>
</p>
	        Will be removed in $validity days, on ${metas[expire]}."
	    else
	        info "error: file transfer interrupted!"
	    fi
        else
	        info "error: file not uploaded or empty!"
        fi
        echo "</div><p><hr><p>"
    fi

    # Section: upload a new file
    local quota=$(freespace)
    echo "<style>#upload-button { display: none; }</style>
    <div id='progress-container' class=container style='display:none; width:600px; border:1px solid #ccc; margin:20px;'>
        <div id='progress-bar' style='width:0%; height:20px; background-color:green; color:white; text-align:center;'>0%</div>
        </div>
    </div>
    <div id='error-message' class='info error container' style='display: none;'></div>
    <form id='upload-form' method='POST' enctype='multipart/form-data' class=container><table class=custom>
         <tr><td class=shrink>Select$another file to upload: <td><input class=btn type='file' id='file-input' name='file' size='64' onchange='checkFile()'>
            <tr id='upload-button' class=expand><td>Then click:<td><input class='btn btn2' type='submit' value='Upload' onclick='window.onbeforeunload = null;'> 
        </table>
    </form>
    <script>
document.getElementById('upload-form').onsubmit = function(e) {
    e.preventDefault();
    var fileInput = document.getElementById('file-input');
    var file = fileInput.files[0];
    if (!file) return;
    if (file.size >= $quota) {
        showError(\"Upload aborted: File '\" + file.name + \"' is too large for the available space of $quota bytes\");
        var uploadButton = document.getElementById('upload-button');
        uploadButton.style.display = 'none';
        fileInput.value = \"\"; // Optional: Clear the input immediately
        return; 
    }

    var formData = new FormData();
    formData.append('file', file);
    var xhr = new XMLHttpRequest();

    document.getElementById('progress-container').style.display = 'block';

    xhr.upload.onprogress = function(e) {
        if (e.lengthComputable) {
            var percent = Math.round((e.loaded / e.total) * 100);
            var bar = document.getElementById('progress-bar');
            bar.style.width = percent + '%';
            bar.textContent = percent + '%';
        }
    };

    xhr.onload = function() {
        // --- THE FIX STARTS HERE ---
        // 1. Kill the 'beforeunload' listener immediately
        window.onbeforeunload = null;

        // 2. Clear the file input so Firefox thinks there is no unsaved data
        fileInput.value = \"\"; 

        // 3. Now it is safe to overwrite the document
        document.open();
        document.write(xhr.responseText);
        document.close();
        // --- THE FIX ENDS HERE ---
    };

    xhr.open('POST', '', true);
    xhr.send(formData);
};
    function checkFile() {
        var fileInput = document.getElementById('file-input');
        var uploadButton = document.getElementById('upload-button');
        showError(\"\");
        if (fileInput.files.length > 0) {
            var file = fileInput.files[0];
            if (file.size >= $quota) {
                showError(\"File '\" + file.name + \"' is too large for the free space of $quota\");
                uploadButton.style.display = 'none';
                fileInput.value = \"\"; // Optional: Clear the input immediately
            } else if (file.size == 0) {
                showError(\"Empty file '\" + file.name + \"', aborted\");
                uploadButton.style.display = 'none';
                fileInput.value = \"\"; // Optional: Clear the input immediately
            } else {
                uploadButton.style.display = 'table-row';
            }
        } else {
            uploadButton.style.display = 'none';
        }
    }
    function showError(msg) {
        var errDiv = document.getElementById('error-message');
        if (msg) {
           errDiv.textContent = msg;
           errDiv.style.display = 'block';
        } else {
          errDiv.style.display = 'none';
        }
    }
</script>"
    # Section: already uploaded
    local now=$(date +%s) days desc last
    echo "<div class=container>Already uploaded:<ul>"
    # shellcheck disable=SC2010,SC2012   # Allow ls instead of find
    for meta in "$data"/*.meta; do
        [[ -e "$meta" ]] || continue
        pass="${meta##*/}"; pass="${pass%.*}"
        meta-read-raw "$meta"
        ((days = ($(date -d "${metas[expire]}" +%s) - now) / 86400 ))
        desc="<li><!--${metas[upload]}--><a href='?mode=log&pass=$pass' title='See its logs'>${metas[hname]}</a>$sp$sp$sp<span class=status>uploaded on ${metas[upload]%%T*}, expires in $days days on ${metas[expire]}</span>"
        if [[ -s "${meta%.*}.log" ]]; then
            last=$(tail -1 "${meta%.*}.log" 2>/dev/null | cut -f 1 -d $'\t')
            echo "$desc, last log on $last"
        else
            echo "$desc <span class=guest>(no access logs yet)</span>"
        fi                  
    done | sort -r
    echo "</ul></div>"
    footer    
}

