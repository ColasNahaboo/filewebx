# sets the color global var to the color of the row
rowcolor(){
    local ip="$1"
    color="${rowkeys[$1]}"
    if [[ -n "$color" ]]; then  # cached
        return
    elif ((rowkey > rowscolmax)); then # overflow, just loop avoid 1rst
        color="${rowscol[1]}"
        rowkey=2
        rowkeys[$ip]="$color"
    else                        # allocate next color from the predefined ones
        color="${rowscol[$rowkey]}"
        ((rowkey++))
        rowkeys[$ip]="$color"
    fi
}
