################################# Main filewebx mode

main() {
    local continued
    header upload
    if [ -n "${FORM_file:-}" ]; then
        continued=" another"
        echo "<div class=minicontainer>"
	if [ -s "$CGIBASHOPTS_DIR/file" ]; then
	    filename="${FORM_file##*/}"
            # only alphanums and [-_.] and avoid starting with dot or hyphen
            filename="${filename//[^-_.~A-Za-z0-9]/}"
            [[ $filename =~ ^[-.] ]] && filename="_$filename"
            # safety: avoid too easily guessable names, or empty ones
            (( ${#filename} < 10 )) && filename="$(random_string 8)-$filename"
            file="$data/$filename"
            size=$(stat -c %s "$file")
            if check-complete "$file" "$size"; then
	        mv "$CGIBASHOPTS_DIR/file" "$file"
                chmod a+rw "$file"
                set-expiration "$validity" "$data" "$filename"
	        name=$(urlencode "$filename")
                hsize=$(human_size "$size")
	        echo "<p>File uploaded ($hsize), can be downloaded as:<p class=resultok>https://${SERVER_NAME}$fwxid/$name</p>"
	        echo "<p>Will be removed in $validity days.</p>"
	    else
	        echo "<p class=resultfail>***Error, file transfer interrupted!</p>"
	    fi
        else
	        echo "<p class=resultfail>***Error, no file uploaded or empty file</p>"
        fi
        echo "</div><p><hr><p>"
    fi
    form_page "$continued"
    footer
}

check-complete(){
    local file="$1" size="$2" expected
    # heuristics: file size + 27% encoding + 3000 bytes of headers
    ((expected = 3000 + (size * 127) / 100))
    if (("$HTTP_CONTENT_LENGTH" < expected)); then
        return 1
    else
        return 0
    fi
}

form_page() {
    local continued="$1"
    echo "
    <style>#upload-button { display: none; }</style>
    <div id='progress-container' class=minicontainer style='display:none; width:600px; border:1px solid #ccc; margin-bottom:10px;'>
        <div id='progress-bar' style='width:0%; height:20px; background-color:green; color:white; text-align:center;'>0%</div>
    </div>
    <form id='upload-form' method='POST' enctype='multipart/form-data' class=container>
        <table>
            <tr><td>Select$continued File: <td><input class=btn type='file' id='file-input' name='file' size='64' onchange='checkFile()'>
            <tr id='upload-button'><td>Then click:<td><input class='btn btn2' type='submit' value='Upload'> 
        </table>
    </form>
    <script>
    document.getElementById('upload-form').onsubmit = function(e) {
        e.preventDefault();
        var file = document.getElementById('file-input').files[0];
        if (!file) return;
        var formData = new FormData();
        formData.append('file', file);
        var xhr = new XMLHttpRequest();
        document.getElementById('progress-container').style.display = 'block';
        xhr.upload.onprogress = function(e) {
            if (e.lengthComputable) {
                var percent = Math.round((e.loaded / e.total) * 100);
                var bar = document.getElementById('progress-bar');
                bar.style.width = percent + '%';
                bar.textContent = percent + '%';
            }
        };
        xhr.onload = function() {
            // Once finished, we replace the whole page with the CGI result
            document.open();
            document.write(xhr.responseText);
            document.close();
        };
        xhr.open('POST', '', true);
        xhr.send(formData);
    };
    function checkFile() {
        var fileInput = document.getElementById('file-input');
        var uploadButton = document.getElementById('upload-button');
        
        if (fileInput.files.length > 0) {
            uploadButton.style.display = 'table-row';
        } else {
            uploadButton.style.display = 'none';
        }
    }
    </script>
    "
}

human_size() {
    local -i bytes=$1
    if (( bytes < 1024 )); then
        echo "${bytes} B"
        return
    fi
    local units=("KB" "MB" "GB" "TB")
    local unit=""
    for unit in "${units[@]}"; do
        # We use a simple integer division for speed
        if (( bytes < 1048576 )); then
            # Calculate with one decimal point using integer math
            echo "$(( (bytes * 10) / 1024 / 10 )).$(( (bytes * 10) / 1024 % 10 )) $unit"
            return
        fi
        bytes=$(( bytes / 1024 ))
    done
}

################################# Logs mode

apachelogsdir=/var/log/apache2
apachelogsname=files_access.log
export dateformat='%Y-%m-%d.%Hh%M,%S' # format to display dates

main-logs() {
    local file qfile logs empty now=$(date +%s) expires
    header logs
    echo "<table class=fwxlog>"
    # thus our own IP is in the dim 1rst color, to better spot others
    rowcolor "$REMOTE_ADDR"
    # shellcheck disable=SC2010
    while read -r file; do
        set_regexp_quote qfile "GET $fwxid/$file "
        logfiles=$(sudo find "$apachelogsdir" -name "$apachelogsname*")
        # shellcheck disable=SC2086
        logs=$(parselogs < <(sudo /usr/bin/zgrep -h "$qfile" $logfiles |sort -r))
        [[ -z "$logs" ]] && empty=true || empty=false
        expires=$(get-expiration "$file" "$now")
        printlogs "$file" "$empty" "$expires" <<<"$logs"
    done < <(cd "$data" || exit 1; ls -t1 | grep -v '^[~]')
    echo "</table>"
    footer
}

printlogs(){
    local file="$1" empty="$2" expires="$3" qfile date ip agent color last
    if "$empty"; then
        echo "<tr class=file><th class=file colspan=3>$file <span class=status>no downloads yet</span></th><th class=expire>Expires in $expires days</tr><tr><td colspan=4>&nbsp;</td></tr>"
        return
    fi
    echo "<tr class=file><th class=file colspan=3>$file</th><th class=expire>Expires in $expires days</tr>"
    echo "<tr class=legend><th>Date+Time<th>IP address<th>Hostname<th>User Agent</tr>"
    while read -r date ip agent; do
        if [[ "$ip" != "$last" ]]; then
            last="$ip"
            rowcolor "$ip"
        fi
        host=$(host "$ip")
        echo "<tr class=log-line style='background-color:$color'><td class=date>$date<td class=ip>$ip<td class=host>$host<td class=useragent>$agent</tr>"
    done
    echo "<tr><td colspan=4>&nbsp;</td></tr>"
}

# 82.66.246.165 - - [2026-02-27T14:53:27+0000] "GET / HTTP/1.1" 403 1977 "-" "Mozilla/5.0 (X11; Linux x86_64; rv:147.0) Gecko/20100101 Firefox/147.0"

parselogs(){
    local line date agent ip
    while read -r line; do
        #               IP                  ISO_DATE                    AGENT
        if [[ $line =~ ^([^[:space:]]+).*\ \[([-+:[:digit:]]{10}T[-+:[:digit:]]+)\]\ .*\ \"([^\"]+)\"$ ]]; then
            date=$(date -d "${BASH_REMATCH[2]}" +"$dateformat")
            agent="${BASH_REMATCH[3]}"
            ip="${BASH_REMATCH[1]}"
            echo "$date $ip $agent"
        else
            echo "$line"
        fi
    done
}


# sets the color global var to the color of the row
rowcolor(){
    local ip="$1"
    color="${rowkeys[$1]}"
    if [[ -n "$color" ]]; then  # cached
        return
    elif ((rowkey > rowscolmax)); then # overflow, just evit the extra color
        color="$rowscolxtra"
    else                        # allocate next color from the predefined ones
        color="${rowscol[$rowkey]}"
        ((rowkey++))
        rowkeys[$ip]="$color"
    fi
}
# static vars for rowcolor()
# a map[ipadress] = color
declare -A rowkeys
