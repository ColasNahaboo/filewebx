create-guest(){
    local gid="${1//[^-_.[:alnum:]]/}" note="$2" gadmin="$3" gpass
    $isadmin || redirect "$url?info=error:+not+admin" # we must be the admin
    set-metas note="$note"
    [[ -n "$gadmin" ]] && metas[admin]=yes || metas[admin]=
    [[ -z "$gid" ]] && redirect "?mode=admin&info=error:+invalid+guest+name"
    # shellcheck disable=SC2010,SC2012,SC2035   # Allow ls instead of find
    gpass=$(ls -1 *"~$gid" | grep -v '[*]' | grep -oPm1 -- '~\K[[:alnum:]]+')
    [[ -n "$gpass" ]] && redirect "?mode=admin&info=error:+existing+guest+name"
    gpass=$(random_string "$passlen" )
    ln -sf "$adminpass" "$gpass~$gid"
    mkdir -p "$data/~$gid"
    meta-write-raw "$data/~$gid"/meta
    redirect "?mode=admin&info=guest+${gid}+created"
}

