########### Delete guest

del-guest(){
    local gid="${1//[^-_.[:alnum:]]/}" name="$2" note="$3" admin="$4"
    local meta="$data/~$gid/meta" trash="$data/trash"
    [[ -e "$meta" ]] || redirect "?mode=admin&info=error:+try+to+delete+unknown+guest+id:+$gid"
    mkdir -p "$trash"/{cgi,data}
    rm -rf "$trash/cgi/"[a-zA-Z0-9]*"~$gid" "$trash/data/~$gid"
