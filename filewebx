          <input type=hidden name=delfile value='$pass'>
          <input class='btn' type='submit' value='Delete'>
          </table></form>"
    footer
}


########### META modification, then redirect to log page

save-file(){
    local pass="$1" note="$2" exp="$3" filename="$4" meta metas
    meta="$data"/"$pass".meta
    [[ -e "$meta" ]] || redirect "?info=error:+edit+unknown+file+id:+$pass"
    meta-read-raw "$meta"
    metas[name]="$filename"
    metas[uname]="$(urlencode "$filename")"
    metas[hname]="$(htmlencode "$filename")"
    metas[url]="${urld}/$pass/${metas[uname]}"
    if [[ $exp =~ ^[[:space:]]*([[:digit:]]+)[[:space:]]*$ ]]; then
        metas[expire]=$(date -d +\ "${BASH_REMATCH[1]}"\ days --iso)
    elif [[ $exp =~ ^[[:space:]]*([[:digit:]]{4}-[[:digit:]]{2}-[[:digit:]]{2})[[:space:]]*$ ]]; then
        metas[expire]="${BASH_REMATCH[1]}"
    fi
    metas[note]=$(htmlencode "$note")
    meta-write-raw "$meta"
    redirect "?mode=log&pass=$pass&info=file+info+saved"
}

########### Delete file

del-file(){
    local pass="$1" trash="$data/trash"
    meta="$data"/"$pass".meta
    [[ -e "$meta" ]] || redirect "?info=error:+delete+unknown+file+id:+$pass"
    mkdir -p "$trash"
    mv "${meta%.meta}"[.,]*  "$trash"
    redirect "?mode=upload&info=file+deleted"
}

gui-logs(){
    local tabs="$1" now=$(date +%s) meta metafiles log pass
    header '' "$tabs"
    info
    echo "<div class=minicontainer>Downloads:</div><table class=fwxlog>"
    # thus our own IP is in the dim 1rst color, to better spot others
    rowcolor "$REMOTE_ADDR"
    metafiles=("$data"/*.meta)
    for meta in "${metafiles[@]}"; do
        [[ -e "$meta" ]] || continue
        log="${meta%.meta}.log"
        pass="${meta##*/}"; pass="${pass%.*}"
        printlogs "$meta" "$log" "$pass" "$now"
    done
    echo "</table>"
    footer
}

# print all the log for one file, but on a single line for sorting by date
printlogs(){
    local meta="$1" log="$2" pass="$3" now="$4"
    local date ip host agent qhost qagent days
    meta-read-raw "$meta"
    ((days = ($(date -d "${metas[expire]}" +%s) - now) / 86400 ))
    echo -n "<!--${metas[upload]}--><tr class=file><th class=file colspan=3><a href='?mode=log&pass=$pass' title='more info'>${metas[hname]}</a></th><th class=expire>Expires in $days days on ${metas[expire]}</tr>" # sort key
    if ! [[ -s "$log" ]]; then
        echo "<tr><td colspan=4><span class=status>no downloads yet</span>"
        return
    fi
    echo -n "<tr class=legend><th>Date+Time<th>IP address<th>Hostname<th>User Agent</tr>"
    while IFS=$'\t' read -r date ip host agent; do
        if [[ "$ip" != "$lastip" ]]; then
            lastip="$ip"
            rowcolor "$ip"
        fi
        qhost=$(htmlencode "$host")
        qagent=$(htmlencode "$agent")
        echo -n "<tr class=log-line style='background-color:$color'><td class=date>$date<td class=ip>$ip<td class=host>$qhost<td class=useragent>$qagent</tr>"
done < <(tac "$log")
    echo "<tr><td colspan=4>&nbsp;"
}

