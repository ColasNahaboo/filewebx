    mv "$data/~$gid" "$trash/data"
    redirect "?mode=admin&info=guest+${gid}_deleted"
}

################################# Misc utils

check-complete(){
    local file="$1" size="$2" expected
    [[ -z "$HTTP_CONTENT_LENGTH" ]] && return 0
    # heuristics: file size + 27% encoding + 3000 bytes of headers
    ((expected = 3000 + (size * 127) / 100))
    if (("$HTTP_CONTENT_LENGTH" < expected)); then
        return 1
    else
        return 0
    fi
}

human_size() {
    local -i bytes=$1
    if (( bytes < 1024 )); then
        echo "${bytes} B"
        return
    fi
    local units=("KB" "MB" "GB" "TB")
    local unit=""
    for unit in "${units[@]}"; do
        # We use a simple integer division for speed
        if (( bytes < 1048576 )); then
            # Calculate with one decimal point using integer math
            echo "$(( (bytes * 10) / 1024 / 10 )).$(( (bytes * 10) / 1024 % 10 )) $unit"
            return
        fi
        bytes=$(( bytes / 1024 ))
    done
}

