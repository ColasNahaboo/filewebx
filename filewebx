################################# Admin mode

main-admin() {
    local nguests=0 id
    $isadmin || { echo "Location:?mode=upload$nl$nl"; exit 0;}
    header admin
    echo "<div class=container>Guest accounts:<uL>"
    for i in "$data/~"*; do
        [[ "${i: -1}" == '*' ]] && continue # no match
        id="${i##*/}"
        sid=$(find . -name "*$id")
        [[ $sid =~ /[[:alnum:]]+[~][-_.[:alnum:]]+$ ]] || continue
        echo "<li><b>${id:1}</b>: <a href='https://$SERVER_NAME${SCRIPT_NAME%/*}/${sid##*/}'><tt>https://$SERVER_NAME${SCRIPT_NAME%/*}/${sid##*/}</tt></a>"
        ((nguests++))
    done
    ((nguests == 0)) && echo "<i>...none...</i>"
    echo "</ul></div>"
    echo "<form id='create-guest' method='POST' enctype='multipart/form-data' class=container>
       <input type=text size=12 name=newguest>
       <input class='btn' type='submit' value='Create new guest'>
       <i>(short id: letters, numbers, hyphen, dot, underscore)</i>
    </form>"   
    footer
}

create-guest(){
    local id="$1" pass=$(random_string 12)
    [[ -n "$id" ]] || return
    ln -sf "${SCRIPT_NAME##*/}" "${pass}~${id}"
    mkdir -p "$data/~$id"
}

################################# Clean mode

main-clean() {
    local nguests=0 id d path file now=$(date +%s) fdate
    $isadmin || { echo "Location:?mode=upload$nl$nl"; exit 0;}
    echo "Content-Type:text/plain$nl"
    for d in "$data/~"*; do
        [[ "${d: -1}" == '*' ]] && continue # no match
        while read -r path; do
            file="${path##*/}"
            if [[ "${file:0:1}" == '.' ]]; then
                if [[ -e "$d/${file:1}" ]]; then
                    (( $(date -r "$path" +%s) < now )) && rm -f "$path" "$d/${file:1}" # obsolete file
                else
                    rm -rf "$path" # orphan dotfile
                fi
            elif ! [[ -e "$d/.${file}" ]]; then # no exp date, set one
                fdate=$(date -r "$path" --iso)
                touch -d "@$(date -d "$fdate +$validity days" +%s)" "$d/.${file}"
            fi
        done < <(find "$d" -type f)
    done
}

################################# Misc utils

# sets the variable in 1rst arg to the quoted 2nd arg string for regexp use,
# quotes also / for safe use in sed /.../
# from: https://github.com/ColasNahaboo/colas-bash-lib/blob/main/lib/regexp_quote.sh v1
set_regexp_quote(){ local -; set +xve; local -n _qs="$1"
  local i c len="${#2}"; _qs=; for (( i=0; i<len; i++ ));do
  c="${2:i:1}";case "$c" in [^][{}?*\|+.$\\\(\)/^])_qs+="$c";;'^')_qs+='\^';;
  *)_qs+="[$c]";;esac;done
}

# returns a random alphanumeric string of N chars, non-nl-terminated
random_string() { # LC_ALL=C avoids unicode multibyte mess
    LC_ALL=C tr -dc 'a-zA-Z0-9' < /dev/urandom | head -c "${1:-12}"
}

# set expiration date as a dotfile
set-expiration(){
    local days="$1" dotfile="$2/.$3"
    # Double quotes nested inside a $() subshell dont conflict with the outer "
    touch -d "@$(date -d "+$days days" +%s)" "$dotfile"
}

# get expiration date from the dotfile. set it if not there
get-expiration(){
    local file="$1" now="$2" fdate dotfile
    dotfile="$data/.$file"
    if ! [[ -e "$dotfile" ]]; then
        fdate=$(date -r "$data/$file" --iso)
        touch -d "@$(date -d "$fdate +$validity days" +%s)" "$dotfile"
    fi
    echo $(( ( $(date -r "$dotfile" +%s) - now) / 86400))
}
