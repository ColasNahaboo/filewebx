# cache calls to host in a static ass. array, a map[ipadress] = hostname
declare -A iphostnames
iphostname=                     # global used for return value
getiphostname(){
    local ip="$1"
    iphostname="${iphostnames[$1]}"
    if [[ -n "$iphostname" ]]; then  # cached
        return
    else                    # allocate next iphostname from the predefined ones
        iphostname=$(host "$ip")
        [[ $iphostname =~ 'domain name pointer '(.+)[.]$ ]] &&
            iphostname="${BASH_REMATCH[1]}"
        iphostnames[$ip]="$iphostname"
    fi
}

################################# Clean mode

clean() {
    local now=$(date +%s) meta pass trash
    echo "Content-Type:text/plain$nl"
    $isadmin || { echo "clean: must be admin, aborted!"; exit 0;}
    for meta in "$data/"*.meta "$data/~"*/*.meta; do
        [[ -e "$meta" ]] || continue # no match
        pass="${meta##*/}"; pass="${pass%.*}"
        meta-read-raw "$meta"
        if (( ($(date -d "${metas[expire]}" +%s) - now) < 0 )); then # expired
            trash="${meta%/*}"/trash
            mkdir -p "$trash"
            mv "${meta%.meta}"[.,]*  "$trash"
        fi
    done
    find "$data" -depth -type d -name trash -exec rm -rf {} \;
}

############ Metadata functions
# from: https://github.com/ColasNahaboo/colas-bash-lib
# metadata are stored in memory as associative arrays key,values
declare -Ag metas

# raw meta files: super efficient, but not very human friendly
# we use the native marsdhalling of data built-in into bash: declare -p
# reads metadata from "raw" file $1, info array named $2" (defaults to "metas")
# the metadata file is a declaration of a global associative array named metas
# resets the metas variable if file does not exists
meta-read-raw(){
    local file="$1" metaname="$2"
    meta-reset "$metaname"
    [[ -s "$file" ]] || return
    if [[ -n "$metaname" ]] && [[ "$metaname" != metas ]]; then
        # rename the declare in a temporary file and then source it
        local tmp="/tmp/meta-raw.$$"
        sed "1s/^declare -Ag metas=/declare -Ag $metaname=/" "$file" > "$tmp"
        source "$tmp"
        rm "$tmp"
    else                        # default name is faster
        source "$file"
    fi
}

# $1=file $2=metadata array name, default  "metas"
# We need to force the declaration to have global scope (with "g" option
# Otherwise sourcing the file inside a function will not work
meta-write-raw(){
    local file="$1" name="${2:-metas}"
    declare -p "$name" |
        sed "1s/^declare -A $name=/declare -Ag metas=/" >"$file"
}

# to clear the metadata
meta-reset(){ local _m="${2:-metas}"; unset "$_m"; declare -Ag "$_m";}

################################# Misc utils

# sets the variable in 1rst arg to the quoted 2nd arg string for regexp use,
# quotes also / for safe use in sed /.../
# from: https://github.com/ColasNahaboo/colas-bash-lib/blob/main/lib/regexp_quote.sh v1
set_regexp_quote(){ local -; set +xve; local -n _qs="$1"
  local i c len="${#2}"; _qs=; for (( i=0; i<len; i++ ));do
  c="${2:i:1}";case "$c" in [^][{}?*\|+.$\\\(\)/^])_qs+="$c";;'^')_qs+='\^';;
  *)_qs+="[$c]";;esac;done
}

# returns a random alphanumeric string of N chars, non-nl-terminated
random_string() { # LC_ALL=C avoids unicode multibyte mess
    LC_ALL=C tr -dc 'a-zA-Z0-9' < /dev/urandom | head -c "${1:-12}"
}

htmlencode() {
    local str="${1//&/\&amp;}"; str="${str//</\&lt;}"; str="${str//>/\&gt;}"
    str="${str//\"/\&quot;}"; echo "${str//\'/\&#39;}"
}

# Encode in the %xx form reserved characters for use in URLS
# Reserved charachers are all non alphanumeric, or -_.~
urlencode() {
    local length="${#1}" i c
    for (( i = 0; i < length; i++ )); do
        c="${1:i:1}"
        case $c in
            [-_.~[:alnum:]]) echo -n "$c" ;;
            *) printf '%%%02X' "'$c" ;;
        esac
    done
}

